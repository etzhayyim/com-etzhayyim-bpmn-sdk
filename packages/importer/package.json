{
  "name": "@etzhayyim/bpmn-sdk-importer",
  "version": "0.1.0",
  "description": "BPMN XML to IR importer (reverse compiler)",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "echo 'Build skipped for importer' || true",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "bpmn-moddle": "^10.0.0",
    "moddle-xml": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "@etzhayyim/bpmn-sdk-core": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/etzhayyim/root.git",
    "directory": "20-actors/etzhayyim-bpmn-sdk/packages/importer"
  }
}
