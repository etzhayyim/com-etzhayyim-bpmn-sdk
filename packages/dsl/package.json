{
  "name": "@etzhayyim/bpmn-sdk-dsl",
  "type": "module",
  "version": "0.1.0",
  "description": "TypeScript DSL for declarative BPMN 2.0 modeling",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "ts-node": "^10.9.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@etzhayyim/bpmn-sdk-core": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/etzhayyim/com-etzhayyim-bpmn-sdk.git"
  },
  "dependencies": {
    "@etzhayyim/bpmn-sdk-core": "workspace:*"
  }
}
