{
  "name": "@etzhayyim/bpmn-sdk-ops",
  "version": "0.1.0",
  "description": "Operations and monitoring for BPMN processes with OpenTelemetry integration",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-jaeger": "^2.9.0",
    "@opentelemetry/exporter-prometheus": "^0.220.0",
    "@etzhayyim/bpmn-sdk-core": "workspace:*",
    "@etzhayyim/bpmn-sdk-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@etzhayyim/bpmn-sdk-core": "workspace:*",
    "@etzhayyim/bpmn-sdk-runtime": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/etzhayyim/com-etzhayyim-bpmn-sdk.git"
  }
}
