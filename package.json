{
  "name": "@etzhayyim/bpmn-sdk",
  "version": "0.1.0",
  "description": "Full BPMN 2.0 SDK with TypeScript DSL and bpmn-engine runtime integration",
  "license": "Apache-2.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "turbo lint",
    "format": "turbo format",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck",
    "docs": "typedoc",
    "docs:serve": "npx http-server docs/api -p 8080"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "turbo": "^2.9.18",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "preact": "10.29.7"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/etzhayyim/com-etzhayyim-bpmn-sdk.git"
  }
}
