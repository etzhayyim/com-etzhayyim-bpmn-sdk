{
  "name": "e2e-minimal",
  "version": "0.1.0",
  "description": "Minimal E2E test for @etzhayyim/bpmn-sdk",
  "type": "commonjs",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@etzhayyim/bpmn-sdk-dsl": "workspace:*",
    "@etzhayyim/bpmn-sdk-compiler": "workspace:*",
    "@etzhayyim/bpmn-sdk-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3",
    "ts-node": "^10.9.0",
    "jest": "^30.4.2"
  }
}
